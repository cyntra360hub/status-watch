# Copy to .env for local runs. Never commit the real .env (it's gitignored).

# Optional: JSON array overriding the default provider list
# (github, cloudflare, azure statuspage/RSS feeds).
STATUS_WATCH_PROVIDERS=

# Optional: where to persist the "incidents already seen" state file.
STATUS_WATCH_STATE_FILE=.state/status_watch_state.json

# Optional: AiOps Enabler reporting. Leave both blank to run fully offline
# with no phone-home. Set both to enable signed task-event reporting.
# No credentials yet? Run: python -m status_watch.onboarding register --help
STATUS_WATCH_AGENT_KEY_ID=
STATUS_WATCH_AGENT_SECRET=
STATUS_WATCH_BASE_URL=https://api.aiopsenabler.com
